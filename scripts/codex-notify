#!/bin/sh

# Codex passes one JSON payload as the final argument to the notify command.
payload=${1:-"{}"}
tmux_label=""
notification_tty=""

# Keep the Codex desktop app's existing turn-ended integration working.
desktop_notifier="$HOME/.codex/computer-use/Codex Computer Use.app/Contents/SharedSupport/SkyComputerUseClient.app/Contents/MacOS/SkyComputerUseClient"
if [ -x "$desktop_notifier" ]; then
    "$desktop_notifier" turn-ended "$payload" >/dev/null 2>&1 &
fi

# Show an in-tmux message as well, so completion is visible on returning to tmux.
if [ -n "${TMUX:-}" ] && command -v tmux >/dev/null 2>&1; then
    tmux_label=$(tmux display-message -p '#S:#I.#P' 2>/dev/null || true)
    if [ -n "${TMUX_PANE:-}" ]; then
        notification_tty=$(tmux display-message -p -t "$TMUX_PANE" '#{client_tty}' 2>/dev/null || true)
    fi
    if [ -n "$tmux_label" ]; then
        tmux display-message "Codex: 回答が完了しました (${tmux_label})" >/dev/null 2>&1 || true
    else
        tmux display-message 'Codex: 回答が完了しました' >/dev/null 2>&1 || true
    fi
fi

# Ask iTerm2 to post the macOS notification. Unlike an osascript notification,
# clicking it activates iTerm2 instead of Script Editor.
notification_body="回答が完了しました"
cwd=$(/usr/bin/printf '%s' "$payload" | /usr/bin/plutil -extract cwd raw -o - - 2>/dev/null || true)
if [ -n "$cwd" ]; then
    notification_body="完了: $cwd"
fi
if [ -n "$tmux_label" ]; then
    notification_body="$notification_body [$tmux_label]"
fi

# Do not allow control characters from the payload to alter the OSC sequence.
notification_body=$(/usr/bin/printf '%s' "$notification_body" | LC_ALL=C /usr/bin/tr -d '\000-\010\013\014\016-\037\177')

if [ -z "$notification_tty" ] && [ -w /dev/tty ]; then
    notification_tty=/dev/tty
fi
case "$notification_tty" in
    /dev/tty*)
        if [ -w "$notification_tty" ]; then
            /usr/bin/printf '\033]9;%s\007' "$notification_body" >"$notification_tty" 2>/dev/null || true
        fi
        ;;
esac
